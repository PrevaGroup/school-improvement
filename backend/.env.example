# Copy to .env and fill in. pydantic reads this file directly — the app never
# `source`s it into the shell, and connection parts are separate fields assembled
# with URL.create, so passwords may contain @ : / $ - etc.
#
# ONE rule: if a password contains a `$`, SINGLE-QUOTE it (as below) so the .env
# parser treats it literally instead of trying to interpolate a variable.

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=sip

# App runtime role: sip_app (non-owner, NOBYPASSRLS) — RLS applies to this connection.
APP_DB_USER=sip_app
APP_DB_PASSWORD='CHANGE_ME_app'

# Migrations role: sip_migrator (owns objects). Used only by Alembic.
MIGRATION_DB_USER=sip_migrator
MIGRATION_DB_PASSWORD='CHANGE_ME_migrator'

# Dev only: allow the X-Dev-Tenant header instead of a real Google token. NEVER in prod.
DEV_MODE=true

# Prod: OAuth client id your Google ID tokens are issued for.
GOOGLE_OAUTH_AUDIENCE=

# --- Cloud SQL ---
# Run the Auth Proxy so 127.0.0.1:5432 tunnels to your instance:
#   cloud-sql-proxy PROJECT:REGION:INSTANCE --port 5432
# Production: prefer Cloud SQL IAM DB auth or Google Secret Manager over a
# password in this file.
