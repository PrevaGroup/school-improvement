# Copy to .env and fill in. pydantic reads this file directly — the app never
# `source`s it into the shell. NON-secret config only lives here; DB passwords
# come from Google Secret Manager (see below), not this file.

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=sip
APP_DB_USER=sip_app
MIGRATION_DB_USER=sip_migrator

# --- Secrets: Google Secret Manager (runbook Phase 3) ---
# The DB passwords are read from Secret Manager via Application Default Credentials.
GCP_PROJECT=school-improvement-501916
APP_DB_PASSWORD_SECRET=sip-app-password
MIGRATION_DB_PASSWORD_SECRET=sip-migrator-password

# --- Dev fallback ONLY (leave commented in normal use) ---
# If set, these literal passwords OVERRIDE Secret Manager. Handy if Secret Manager
# access is blocked. Single-quote any value containing a `$`. Never commit real ones.
# APP_DB_PASSWORD='...'
# MIGRATION_DB_PASSWORD='...'

DEV_MODE=true
GOOGLE_OAUTH_AUDIENCE=

# --- Cloud SQL ---
# Run the Auth Proxy so 127.0.0.1:5432 tunnels to your instance:
#   cloud-sql-proxy PROJECT:REGION:INSTANCE --port 5432
