# Copy to .env and fill in. Two DB URLs on purpose (checklist: migrate as a
# separate, more-privileged role than the app runtime).

# App runtime — connects as the NON-owner, NON-superuser, NOBYPASSRLS role.
# This is the connection RLS actually applies to.
DATABASE_URL=postgresql+psycopg://sip_app:CHANGE_ME_app@127.0.0.1:5432/sip

# Migrations — connects as the owner / more-privileged role.
MIGRATION_DATABASE_URL=postgresql+psycopg://sip_migrator:CHANGE_ME_migrator@127.0.0.1:5432/sip

# Name of the runtime role that migration 0001 grants table privileges to.
APP_DB_ROLE=sip_app

# Dev only: allow the X-Dev-Tenant header instead of a real Google token. NEVER in prod.
DEV_MODE=true

# Prod: the OAuth client ID your Google ID tokens are issued for (audience check).
GOOGLE_OAUTH_AUDIENCE=

# --- Cloud SQL ---
# Easiest path: run the Auth Proxy so 127.0.0.1:5432 tunnels to your instance:
#   cloud-sql-proxy PROJECT:REGION:INSTANCE --port 5432
# Then the URLs above work unchanged. For IAM DB auth / the Python Connector,
# see app/db.py comments.
