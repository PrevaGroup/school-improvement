# Copy to .env and fill in. pydantic reads this file directly — the app never
# `source`s it into the shell. NON-secret config only lives here; DB passwords
# come from Google Secret Manager (see below), not this file.

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=sip
APP_DB_USER=sip_app
MIGRATION_DB_USER=sip_migrator

# --- Secrets: Google Secret Manager (runbook Phase 3) ---
# The DB passwords are read from Secret Manager via Application Default Credentials.
GCP_PROJECT=school-improvement-501916
APP_DB_PASSWORD_SECRET=sip-app-password
MIGRATION_DB_PASSWORD_SECRET=sip-migrator-password

# --- Dev fallback ONLY (leave commented in normal use) ---
# If set, these literal passwords OVERRIDE Secret Manager. Handy if Secret Manager
# access is blocked. Single-quote any value containing a `$`. Never commit real ones.
# APP_DB_PASSWORD='...'
# MIGRATION_DB_PASSWORD='...'

DEV_MODE=true

# --- Auth (GCIP) ---
# Audience the ID token must carry; defaults to GCP_PROJECT if left blank.
GOOGLE_OAUTH_AUDIENCE=
#
# WHO MAY SIGN IN AT ALL. Comma-separated, exact domains (not JSON — see backend/DEPLOY.md
# for why, and for the gcloud ^@^ delimiter needed to pass a value containing commas).
# Authentication is NOT invitation: with Google sign-in enabled, any Gmail can get a valid
# token, so this is the actual gate. FAILS CLOSED — unset means nobody gets in.
ALLOWED_EMAIL_DOMAINS=prevagroup.com,gatesfoundation.org
#
# How a verified identity becomes a tenant (app/security.py). Separate question from the
# allowlist above: that one decides WHO gets in, this one decides WHAT THEY SEE. An invited
# tester has no tenant and sees only public data — that's the normal case, not an error.
#   1) custom claim on the user (recommended): the claim name to read.
TENANT_CLAIM=tenant_id
#   2) fallback: map email domain -> tenant_id (JSON). Leave {} to disable.
# DOMAIN_TENANT_MAP='{"lbschools.net": "lbusd"}'

# --- Anthropic (SIP extractor) ---
# Dev fallback only; prod reads Secret Manager `anthropic-api-key`.
# ANTHROPIC_API_KEY=

# --- Cloud SQL Python Connector (Cloud Run; leave blank to use the Auth Proxy) ---
# INSTANCE_CONNECTION_NAME=school-improvement-501916:us-central1:school-improvement-sql
# DB_IP_TYPE=public

# --- Cloud SQL ---
# Run the Auth Proxy so 127.0.0.1:5432 tunnels to your instance:
#   cloud-sql-proxy PROJECT:REGION:INSTANCE --port 5432
